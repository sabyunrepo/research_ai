{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://research-ai.local/deck-harness/asset-review.schema.json",
  "title": "Deck Asset Review",
  "type": "object",
  "additionalProperties": false,
  "required": ["reviewedAt", "reviewMethod", "assets"],
  "properties": {
    "reviewedAt": {
      "type": "string",
      "minLength": 1
    },
    "reviewMethod": {
      "type": "string",
      "minLength": 1
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "assetId",
          "sourcePath",
          "assetSha256",
          "semanticRequirementsSha256",
          "imageDimensions",
          "reviewerMethod",
          "status",
          "score",
          "summary",
          "mustShowResults",
          "forbiddenElementFindings"
        ],
        "properties": {
          "assetId": {
            "type": "string",
            "minLength": 1
          },
          "sourcePath": {
            "type": "string",
            "minLength": 1
          },
          "assetSha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "semanticRequirementsSha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "imageDimensions": {
            "type": "object",
            "additionalProperties": false,
            "required": ["width", "height"],
            "properties": {
              "width": {
                "type": "integer",
                "minimum": 1
              },
              "height": {
                "type": "integer",
                "minimum": 1
              }
            }
          },
          "reviewerMethod": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["PASS", "FAIL", "WARN"]
          },
          "score": {
            "type": "number",
            "minimum": 0,
            "maximum": 100
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "mustShowResults": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["label", "result", "evidence", "observation", "evidencePath"],
              "properties": {
                "label": {
                  "type": "string",
                  "minLength": 1
                },
                "result": {
                  "type": "string",
                  "enum": ["PASS", "FAIL"]
                },
                "evidence": {
                  "type": "string",
                  "minLength": 1
                },
                "observation": {
                  "type": "string",
                  "minLength": 1
                },
                "evidencePath": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          "forbiddenElementFindings": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["label", "observed", "evidence", "observation", "evidencePath"],
              "properties": {
                "label": {
                  "type": "string",
                  "minLength": 1
                },
                "observed": {
                  "type": "boolean"
                },
                "evidence": {
                  "type": "string",
                  "minLength": 1
                },
                "observation": {
                  "type": "string",
                  "minLength": 1
                },
                "evidencePath": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      }
    }
  },
  "$comment": "Runtime validation in verify-deck-quality.js additionally checks assetId uniqueness and requires exactly one mustShowResults/forbiddenElementFindings row for each matching semanticRequirements label. forbiddenElementFindings.observed=true means the forbidden element is present and blocks projector PASS."
}
