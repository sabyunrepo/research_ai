{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://research-ai.local/deck-harness/slide-spec.schema.json",
  "title": "Slide Spec",
  "type": "object",
  "additionalProperties": false,
  "required": ["timeboxMinutes", "slides"],
  "properties": {
    "timeboxMinutes": {
      "type": "integer",
      "minimum": 1
    },
    "slides": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "section",
          "sectionObjective",
          "estimatedMinutes",
          "title",
          "message",
          "bullets",
          "visualIntent",
          "speakerNote",
          "evidenceClaimIds",
          "glossaryTerms",
          "qualityChecks"
        ],
        "not": {
          "anyOf": [
            {
              "required": ["source"]
            },
            {
              "required": ["sources"]
            },
            {
              "required": ["sourceUrl"]
            },
            {
              "required": ["sourceUrls"]
            },
            {
              "required": ["checkedDate"]
            },
            {
              "required": ["sourceType"]
            },
            {
              "required": ["confidence"]
            },
            {
              "required": ["sourceSummary"]
            },
            {
              "required": ["sourceSummaries"]
            }
          ]
        },
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "section": {
            "type": "string",
            "minLength": 1
          },
          "sectionObjective": {
            "type": "string",
            "minLength": 1
          },
          "estimatedMinutes": {
            "type": "integer",
            "minimum": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "message": {
            "type": "string",
            "minLength": 1
          },
          "bullets": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "visualIntent": {
            "type": "string",
            "minLength": 1
          },
          "speakerNote": {
            "type": "string",
            "minLength": 1
          },
          "evidenceClaimIds": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^claim-[0-9]{3,}$"
            }
          },
          "glossaryTerms": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "qualityChecks": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "presenterCues": {
            "type": "array",
            "maxItems": 3,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "bridge": {
            "type": "string",
            "minLength": 1
          },
          "visualType": {
            "type": "string",
            "enum": ["generated-image", "existing-image", "practice-ui", "artifact", "minimal-diagram"]
          },
          "layoutTemplate": {
            "type": "string",
            "enum": [
              "act-opener",
              "story-scene",
              "assertion-evidence",
              "concept-map",
              "checklist",
              "glossary-bridge",
              "practice-handoff",
              "wrap-up"
            ]
          },
          "teachingMove": {
            "type": "string",
            "enum": ["activate", "frame", "explain", "demonstrate", "connect", "practice-bridge", "synthesize"]
          },
          "audienceAction": {
            "type": "string",
            "enum": ["orient", "inspect-visual", "compare", "connect-metaphor", "rehearse-checklist", "transfer-to-practice", "reflect"]
          },
          "visualMode": {
            "type": "string",
            "enum": [
              "story-illustration",
              "metaphor-link",
              "process-diagram",
              "checklist-board",
              "term-bridge",
              "artifact-map",
              "practice-transition",
              "no-image-handoff"
            ]
          },
          "mainTemplate": {
            "type": "string",
            "enum": [
              "opening-hero",
              "kimai-structure",
              "assertion-scene",
              "term-bridge",
              "workflow-strip",
              "decision-gate",
              "brief-window",
              "practice-handoff",
              "recap-map",
              "single-concept"
            ]
          },
          "visualAsset": {
            "type": "string",
            "minLength": 1
          },
          "visualAssetId": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "visualPrompt": {
            "type": "string",
            "minLength": 1
          },
          "xmlPrompt": {
            "type": "object",
            "additionalProperties": false,
            "required": ["instruction", "screenContent", "speakerNavigation", "assetRequirement"],
            "properties": {
              "instruction": {
                "type": "string",
                "minLength": 1
              },
              "screenContent": {
                "type": "string",
                "minLength": 1
              },
              "speakerNavigation": {
                "type": "string",
                "minLength": 1
              },
              "assetRequirement": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "interaction": {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "description"],
            "properties": {
              "type": {
                "type": "string",
                "enum": ["none", "tooltip", "click-reveal", "input-form", "checklist", "preview"]
              },
              "description": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    }
  },
  "$comment": "slide-spec.json must not contain source URLs, checkedDate, sourceType, confidence, or source summaries. evidenceClaimIds is the only bridge to claim-source-map.json. Total slide estimatedMinutes must not exceed the declared timebox; enforce cross-file and sum checks in the contract validator."
}
