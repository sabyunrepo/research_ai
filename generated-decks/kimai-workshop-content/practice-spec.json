        "optionCategories": [
          "required",
          "conditional",
          "distractor"
        ]
      },
      "questionSeeds": [
        {
          "id": "product-review-report",
          "title": "제품 리뷰자료 보고서",
          "prompt": "김아이에게 다음 주 경영회의에 제출할 제품 리뷰자료 보고서를 준비하게 해야 합니다. 어떤 정보를 함께 줘야 할까요? 모두 고르세요.",
          "required": [
            "제품 범위",
            "보고서 독자",
            "리뷰 기간과 비교 기준",
            "필수 지표 또는 자료",
            "제출 형식과 분량",
            "완료 기준과 제출 기한"
          ],
          "conditional": [
            "지난 회의 질문 목록",
            "경쟁 제품 리뷰 기사 2~3개",
            "내부 표현 예시"
          ],
          "distractor": [
            "회사 전체 연혁 자료",
            "미확정 다음 분기 기능 아이디어",
            "관련 없는 고객 문의 전체 원문",
            "임원들이 좋아할 만하게 고급스럽게라는 단독 지시"
          ]
        },
        {
          "id": "payment-button-bug",
          "title": "결제 버튼 오류 수정"
        },
        {
          "id": "slide-improvement",
          "title": "발표자료 슬라이드 다듬기"
        }
      ],
      "generatedOutput": [
        "blank-spaces-report",
        "manager-type-title",
        "selection-analysis",
        "verification-log"
      ],
      "verification": {
        "checks": [
          "required-info-check",
          "scope-noise-check",
          "ambiguity-check",
          "actionability-check"
        ],
        "scoring": {
          "required": "+10~+20",
          "conditional": "+2~+6",
          "overScoped": "-3~-8",
          "polluting": "-8~-15"
        }
      },
      "retryPolicy": {
        "minimumAttempts": 3,
        "retryUnit": "question",
